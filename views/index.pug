extends layout

block content
  h1= title
  p Welcome to #{title}. This paragraph text has been updated in index.pug.
  button(type="button", class="btn btn-secondary", onclick="reduce()") Press me
  div(id="use") take some away
  script.
    let current = 11;
    let quantity = 2;

    function reduce() {
      current = current - quantity;
      if (current < 0) {
        current = 0;
      }
      document.getElementById('use').textContent = `Reduced by ${quantity} to ${current}`;
    }
